{
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"editor.formatOnSave": true,
	"editor.tabSize": 2,
	"editor.insertSpaces": false,
	"files.eol": "\n",
	"search.exclude": {
		"**/.github": true,
		"**/dist": true,
		"**/node_modules": true,
		"**acronymWords.json": true,
		"pnpm-lock.yaml": true,
		"LICENSE": true,
		"README.md": true
	},
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"[svg]": {
		"editor.defaultFormatter": "jock.svg"
	},
	"[typescript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[vue]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[javascript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[html]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	}
}
