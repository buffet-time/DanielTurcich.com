{
	"name": "danielturcich.com",
	"version": "1.0.0",
	"private": true,
	"description": "My website, a bio and portfolio site.",
	"author": {
		"name": "Daniel Turcich",
		"email": "packageJson@danielTurcich.com",
		"url": "https://danielTurcich.com"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:network": "vite --host",
		"build": "vite build --emptyOutDir && pnpm generate:404 && pnpm add:cname",
		"lint-fix": "oxlint --fix",
		"lint-check": "oxlint",
		"format-fix": "oxfmt",
		"format-check": "oxfmt --check",
		"type-check": "vue-tsc --noEmit",
		"checks": "pnpm lint-check && pnpm format-check && pnpm type-check",
		"preview": "vite preview",
		"prepare": "husky",
		"add:cname": "cd dist && echo 'danielturcich.com' > CNAME",
		"generate:404": "cd dist && cp index.html 404.html"
	},
	"dependencies": {
		"dialog-polyfill": "^0.5.6",
		"pinia": "^4.0.2",
		"vue": "^3.5.40",
		"vue-router": "^5.2.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.3.3",
		"@types/lodash.debounce": "^4.0.9",
		"@types/node": "^26.1.1",
		"@vitejs/plugin-vue": "^6.0.8",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"postcss": "^8.5.20",
		"rollup-plugin-gzip": "^4.2.0",
		"rollup-plugin-swc-minify": "^1.3.0",
		"tailwindcss": "^4.3.3",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vue-tsc": "^3.3.7"
	},
	"engines": {
		"node": "^26.1.0",
		"pnpm": "^11.1.2"
	},
	"engineStrict": true,
	"packageManager": "pnpm@11.1.2"
}
